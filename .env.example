# ---------------------------------------------------------------------------
# Required — LLM provider (pick one)
# ---------------------------------------------------------------------------

# OpenAI directly
OPENAI_API_KEY=sk-...

# OR via OpenRouter (prefix must be sk-or-)
# OPENAI_API_KEY=sk-or-...
# AGENT_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# Optional — web search
# ---------------------------------------------------------------------------
# WEB_SEARCH_BACKEND=duckduckgo   # default (no key required)
# WEB_SEARCH_BACKEND=tavily       # requires TAVILY_API_KEY
# TAVILY_API_KEY=tvly-...
# WEB_SEARCH_BACKEND=scrapingdog  # requires SCRAPINGDOG_API_KEY
# SCRAPINGDOG_API_KEY=...

# ---------------------------------------------------------------------------
# Agent tuning
# ---------------------------------------------------------------------------
# AGENT_MAX_ITER=10
# AGENT_MAX_MEMORY=50
# AGENT_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Test flags (do NOT set these in production .env)
# ---------------------------------------------------------------------------
# AGENT_E2E_LIVE=1    → run live LLM test in test_agent_e2e.py
# WEB_SEARCH_LIVE=1   → run live web-search tests in test_web_search.py
